---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostCard from "@/components/PostCard.astro";
import NoteCard from "@/components/NoteCard.astro";
import { getNotes, getPosts } from "@/lib/content";

const posts = await getPosts();
const notes = await getNotes();
const latestPosts = posts.slice(0, 5);
const currentPosts = posts.filter((post) => post.data.status === "current").slice(0, 3);
---

<BaseLayout>
  <section class="hero-home">
    <div class="hero-bg"></div>
    <div class="hero-content">
      <p class="hero-type" data-typewriter="让知识入卷，让思考成章..."><span data-typewriter-text></span><span class="cursor">_</span></p>
      <a class="scroll-cue" href="#inn-board" aria-label="向下浏览">
        <span></span>
      </a>
    </div>
  </section>

  <main class="content-shell home-content" id="inn-board">
    <section class="content-board">
      <section class="home-module">
        <div class="section-head">
          <h2>新近入栈</h2>
          <a href="/archives/">看全部</a>
        </div>
        <div class="post-list">
          {latestPosts.map((post) => <PostCard post={post} />)}
        </div>
      </section>

      <div class="split-grid">
        <section class="home-module">
          <div class="section-head">
            <h2>正在学习</h2>
          </div>
          <div class="mini-list">
            {currentPosts.map((post) => (
              <a class="mini-item" href={`/posts/${post.slug}/`}>
                <strong>{post.data.title}</strong>
                <p>{post.data.description}</p>
              </a>
            ))}
          </div>
        </section>
        <section class="home-module">
          <div class="section-head">
            <h2>近札</h2>
            <a href="/notes/">看札</a>
          </div>
          <div class="mini-list">
            {notes.slice(0, 3).map((note) => <NoteCard note={note} />)}
          </div>
        </section>
      </div>
    </section>
  </main>
  <script>
    const typeTarget = document.querySelector("[data-typewriter-text]");
    const source = document.querySelector("[data-typewriter]")?.getAttribute("data-typewriter") || "";
    if (typeTarget) {
      let index = 0;
      const tick = () => {
        typeTarget.textContent = source.slice(0, index);
        index += 1;
        if (index <= source.length) window.setTimeout(tick, 92);
      };
      tick();
    }
  </script>
</BaseLayout>
